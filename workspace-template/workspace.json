{
  "name": "general",
  "description": "General-purpose assistant workspace",
  "model": "llama3.1:8b",
  "port": 3000,
  "tokenBudget": {
    "maxTotal": 8192,
    "reserveForResponse": 2048,
    "contextTarget": 6144
